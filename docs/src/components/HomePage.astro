<script>
	const root = document.querySelector('[data-rk-home]');
	if (root) {
		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const fine = window.matchMedia('(pointer: fine)').matches;

		// Scroll reveal
		const revealItems = root.querySelectorAll('[data-rk-reveal]');
		if (reduce || !('IntersectionObserver' in window)) {
			revealItems.forEach((item) => item.classList.add('is-visible'));
		} else {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.16, rootMargin: '0px 0px -8% 0px' },
			);
			revealItems.forEach((item) => observer.observe(item));
		}

		// Advanced interactions: pointer spotlight + magnetic primary button (fine pointer only, respects reduce-motion)
		if (fine && !reduce) {
			root.querySelectorAll('[data-spot]').forEach((card) => {
				let raf = 0;
				card.addEventListener('pointermove', (event) => {
					if (raf) return;
					raf = requestAnimationFrame(() => {
						raf = 0;
						const rect = card.getBoundingClientRect();
						card.style.setProperty('--mx', `${((event.clientX - rect.left) / rect.width) * 100}%`);
						card.style.setProperty('--my', `${((event.clientY - rect.top) / rect.height) * 100}%`);
					});
				});
			});

			root.querySelectorAll('[data-magnetic]').forEach((btn) => {
				let raf = 0;
				btn.addEventListener('pointermove', (event) => {
					if (raf) return;
					raf = requestAnimationFrame(() => {
						raf = 0;
						const rect = btn.getBoundingClientRect();
						const x = (event.clientX - rect.left - rect.width / 2) / rect.width;
						const y = (event.clientY - rect.top - rect.height / 2) / rect.height;
						btn.style.transform = `translate(${x * 7}px, ${y * 7}px)`;
					});
				});
				btn.addEventListener('pointerleave', () => {
					btn.style.transform = '';
				});
			});
		}
	}
</script>

<script>
	// Component showcase: the right panel scrolls naturally, an IntersectionObserver detects which component is at the viewport midline and smoothly switches the left copy
	import { scroll } from 'motion';

	const cmp = document.querySelector('[data-cmp]');
	const reduceCmp = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (cmp && !reduceCmp && window.innerWidth > 980) {
		const copies = Array.from(cmp.querySelectorAll('[data-cmp-copy]'));
		const panels = Array.from(cmp.querySelectorAll('[data-cmp-panel]'));
		const fill = cmp.querySelector('[data-cmp-fill]');
		let cur = -1;
		const setActive = (i) => {
			if (i < 0 || i === cur) return;
			cur = i;
			cmp.dataset.index = String(i);
			copies.forEach((el, k) => el.classList.toggle('is-active', k === i));
		};

		// Whichever panel crosses the viewport midline activates the matching copy
		const io = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.isIntersecting) setActive(panels.indexOf(e.target));
				}
			},
			{ rootMargin: '-50% 0px -50% 0px' },
		);
		panels.forEach((p) => io.observe(p));

		// Progress bar follows the overall scroll
		if (fill) {
			scroll(
				(progress) => {
					fill.style.width = `${Math.min(100, progress * 100).toFixed(1)}%`;
				},
				{ target: cmp, offset: ['start start', 'end end'] },
			);
		}
	}
</script>

<script>
	// Quick-start two acts: driven by Motion scroll() (desktop, non-reduce-motion; narrow screens and fallbacks use static CSS)
	import { scroll } from 'motion';

	const qs = document.querySelector('.rk-qs');
	const reduceQs = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (qs && !reduceQs && window.innerWidth > 980) {
		// Act one: left copy + right code window, scroll progress drives a typewriter (types raw in the first half, switches copy and retypes kit in the second)
		const act1 = qs.querySelector('[data-qs-act1]');
		if (act1) {
			const titleEl = act1.querySelector('[data-qs-title]');
			const phaseFill = act1.querySelector('[data-qs-phasefill]');
			const rawLayer = act1.querySelector('[data-qs-code="raw"]');
			const kitLayer = act1.querySelector('[data-qs-code="kit"]');
			const rawLines = rawLayer ? Array.from(rawLayer.querySelectorAll('.line')) : [];
			const kitLines = kitLayer ? Array.from(kitLayer.querySelectorAll('.line')) : [];
			const titles = { raw: 'main.rs · plain ratatui', kit: 'counter.rs · ratatui-kit' };

			const typeset = (lines, n) => {
				const caret = n > 0 && n <= lines.length ? n - 1 : -1;
				for (let i = 0; i < lines.length; i++) {
					lines[i].classList.toggle('typed', i < n);
					lines[i].classList.toggle('caret', i === caret);
				}
			};

			act1.classList.add('is-typing');
			let phase = '';
			scroll(
				(progress) => {
					const next = progress < 0.5 ? 'raw' : 'kit';
					if (next !== phase) {
						phase = next;
						act1.dataset.phase = phase;
						if (titleEl) titleEl.textContent = titles[phase];
					}
					if (phaseFill) phaseFill.style.width = `${Math.min(100, progress * 100).toFixed(1)}%`;
					if (phase === 'raw') {
						const t = Math.min(1, progress / 0.46); // finish typing raw within the first half
						typeset(rawLines, Math.round(t * rawLines.length));
						typeset(kitLines, 0);
					} else {
						const t = Math.min(1, (progress - 0.5) / 0.46); // finish typing kit within the second half
						typeset(rawLines, rawLines.length);
						typeset(kitLines, Math.round(t * kitLines.length));
					}
				},
				{ target: act1, offset: ['start start', 'end end'] },
			);
		}

		// Act two: the three right blocks scroll naturally, an IntersectionObserver cumulatively lights up the left steps (passed steps stay highlighted)
		const act2 = qs.querySelector('[data-qs-act2]');
		const fill2 = act2 ? act2.querySelector('[data-qs-fill]') : null;
		const steps2 = act2 ? Array.from(act2.querySelectorAll('.rk-qs-step')) : [];
		const panels2 = act2 ? Array.from(act2.querySelectorAll('[data-qs-panel]')) : [];

		if (act2 && panels2.length) {
			let curStep = 0;
			const setStep = (n) => {
				if (n === curStep) return;
				curStep = n;
				act2.dataset.step = String(n);
				steps2.forEach((el, k) => el.classList.toggle('is-on', k < n));
			};

			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.isIntersecting) setStep(Number(e.target.dataset.qsPanel));
					}
				},
				{ rootMargin: '-50% 0px -50% 0px' },
			);
			panels2.forEach((p) => io.observe(p));
			setStep(1);

			if (fill2) {
				scroll(
					(progress) => {
						fill2.style.height = `${Math.min(100, progress * 100).toFixed(1)}%`;
					},
					{ target: act2, offset: ['start start', 'end end'] },
				);
			}
		}
	}
</script>

