---
const pillars = [
	{
		title: 'Declarative UI',
		text: 'Build terminal screens from component trees with `element!`, first-class control flow, props, and stable keys.',
	},
	{
		title: 'Reactive hooks',
		text: 'Keep local state, async tasks, effects, memoized values, context, and input handlers attached to component instances.',
	},
	{
		title: 'Input isolation',
		text: 'Use layers and consumable handlers so modals, search boxes, and edit modes do not leak keys to background views.',
	},
	{
		title: 'Ratatui-native escape hatches',
		text: 'Drop down to native widgets or hand-written components when the built-in abstractions should stay out of your way.',
	},
];

const paths = [
	{
		title: 'Start with a counter',
		href: 'start/quick-start/',
		text: 'Run the smallest reactive app and see state writes wake the render loop.',
	},
	{
		title: 'Learn the runtime model',
		href: 'core/component-model/',
		text: 'Understand elements, components, instantiated nodes, hooks, keys, and transparent layout.',
	},
	{
		title: 'Handle real input',
		href: 'tutorials/input-mutex/',
		text: 'Use input layers to coordinate lists, modals, and edit modes without shortcut conflicts.',
	},
	{
		title: 'Compose a full app',
		href: 'apps/todo-app/',
		text: 'Combine state, search input, confirmation modals, and routing into a complete workflow.',
	},
];

const counterCode = `#[component]
fn Counter(mut hooks: Hooks) -> impl Into<AnyElement<'static>> {
    let mut count = hooks.use_state(|| 0);

    hooks.use_future(async move {
        loop {
            tokio::time::sleep(Duration::from_secs(1)).await;
            count += 1;
        }
    });

    element!(Text(text: format!("Counter: {}", count.get())))
}`;
---

<section class="rk-en-home" aria-labelledby="rk-en-title">
	<div class="rk-en-home__hero">
		<div>
			<p class="rk-en-home__eyebrow">Ratatui component framework</p>
			<h1 id="rk-en-title">Build terminal apps with components, hooks, and async state.</h1>
			<p class="rk-en-home__lead">
				Ratatui Kit adds React-style composition, identity, state retention, scoped input routing, and
				Tokio-friendly rendering on top of Ratatui.
			</p>
			<div class="rk-en-home__actions">
				<a class="rk-en-home__button rk-en-home__button--primary" href="start/quick-start/">Quick start</a>
				<a class="rk-en-home__button" href="components/">Browse components</a>
			</div>
		</div>
		<pre class="rk-en-home__code" aria-label="Ratatui Kit counter sketch"><code>{counterCode}</code></pre>
	</div>

	<div class="rk-en-home__grid" aria-label="Framework pillars">
		{pillars.map((pillar) => (
			<article>
				<h2>{pillar.title}</h2>
				<p>{pillar.text}</p>
			</article>
		))}
	</div>

	<section class="rk-en-home__path" aria-labelledby="rk-en-path-title">
		<div>
			<p class="rk-en-home__eyebrow">Learning path</p>
			<h2 id="rk-en-path-title">From one component to a complete terminal workflow</h2>
		</div>
		<ol>
			{paths.map((item) => (
				<li>
					<a href={item.href}>{item.title}</a>
					<p>{item.text}</p>
				</li>
			))}
		</ol>
	</section>
</section>

<style>
	.rk-en-home {
		--rk-ink: #122021;
		--rk-muted: #526467;
		--rk-surface: #f7faf8;
		--rk-line: color-mix(in srgb, var(--sl-color-gray-5), transparent 30%);
		--rk-accent: #0a7c7f;
		--rk-accent-strong: #075c62;
		max-width: 1120px;
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 5rem) 1rem 4rem;
		color: var(--sl-color-white);
	}

	:root[data-theme='light'] .rk-en-home {
		color: var(--rk-ink);
	}

	.rk-en-home__hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.82fr);
		gap: clamp(1.5rem, 4vw, 4rem);
		align-items: center;
		min-height: min(660px, calc(100vh - 8rem));
	}

	.rk-en-home__eyebrow {
		margin: 0 0 0.85rem;
		color: var(--rk-accent);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0;
	}

	.rk-en-home h1 {
		max-width: 12ch;
		margin: 0;
		font-size: clamp(3rem, 8vw, 6.8rem);
		line-height: 0.94;
		letter-spacing: 0;
	}

	.rk-en-home__lead {
		max-width: 42rem;
		margin: 1.35rem 0 0;
		color: var(--rk-muted);
		font-size: clamp(1.05rem, 2vw, 1.3rem);
		line-height: 1.65;
	}

	:root[data-theme='dark'] .rk-en-home__lead {
		color: var(--sl-color-gray-3);
	}

	.rk-en-home__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.rk-en-home__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.7rem 1rem;
		border: 1px solid var(--rk-line);
		border-radius: 0.45rem;
		color: inherit;
		font-weight: 750;
		text-decoration: none;
	}

	.rk-en-home__button--primary {
		border-color: var(--rk-accent);
		background: var(--rk-accent);
		color: #fff;
	}

	.rk-en-home__button:hover {
		border-color: var(--rk-accent-strong);
		color: var(--rk-accent-strong);
	}

	.rk-en-home__button--primary:hover {
		color: #fff;
		background: var(--rk-accent-strong);
	}

	.rk-en-home__code {
		margin: 0;
		padding: clamp(1rem, 2vw, 1.35rem);
		overflow-x: auto;
		border: 1px solid var(--rk-line);
		border-radius: 0.5rem;
		background: color-mix(in srgb, var(--sl-color-bg-nav), var(--sl-color-gray-6) 20%);
		box-shadow: 0 1rem 3rem color-mix(in srgb, #001014, transparent 86%);
		font-size: clamp(0.72rem, 1.4vw, 0.92rem);
		line-height: 1.65;
	}

	.rk-en-home__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		margin-top: clamp(1.5rem, 5vw, 4rem);
		border: 1px solid var(--rk-line);
		background: var(--rk-line);
	}

	.rk-en-home__grid article {
		min-height: 13rem;
		padding: 1.25rem;
		background: var(--sl-color-bg);
	}

	.rk-en-home__grid h2,
	.rk-en-home__path h2 {
		margin: 0;
		font-size: clamp(1.3rem, 2.4vw, 2rem);
		line-height: 1.1;
		letter-spacing: 0;
	}

	.rk-en-home__grid p,
	.rk-en-home__path p {
		margin: 1rem 0 0;
		color: var(--rk-muted);
		line-height: 1.65;
	}

	:root[data-theme='dark'] .rk-en-home__grid p,
	:root[data-theme='dark'] .rk-en-home__path p {
		color: var(--sl-color-gray-3);
	}

	.rk-en-home__path {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: clamp(1.5rem, 4vw, 4rem);
		margin-top: clamp(2.5rem, 6vw, 5rem);
		padding-top: clamp(2rem, 4vw, 4rem);
		border-top: 1px solid var(--rk-line);
	}

	.rk-en-home__path ol {
		display: grid;
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
		counter-reset: path;
	}

	.rk-en-home__path li {
		position: relative;
		padding-left: 3rem;
		counter-increment: path;
	}

	.rk-en-home__path li::before {
		position: absolute;
		left: 0;
		top: 0.05rem;
		width: 2rem;
		height: 2rem;
		display: grid;
		place-items: center;
		border: 1px solid var(--rk-line);
		border-radius: 999px;
		content: counter(path);
		color: var(--rk-accent);
		font-weight: 800;
	}

	.rk-en-home__path a {
		color: inherit;
		font-size: 1.1rem;
		font-weight: 800;
		text-decoration-color: color-mix(in srgb, var(--rk-accent), transparent 55%);
		text-underline-offset: 0.25rem;
	}

	@media (max-width: 840px) {
		.rk-en-home__hero,
		.rk-en-home__path {
			grid-template-columns: 1fr;
			min-height: 0;
		}

		.rk-en-home h1 {
			max-width: 13ch;
		}

		.rk-en-home__grid {
			grid-template-columns: 1fr;
		}

		.rk-en-home__grid article {
			min-height: auto;
		}
	}
</style>
