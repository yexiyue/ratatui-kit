---
import { Code } from 'astro:components';
import { RK_VERSION } from '../consts';

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
const recording = (name: string) => `${baseUrl}recordings/${name}.gif`;
const repoUrl = 'https://github.com/yexiyue/ratatui-kit';

// Dual light/dark code highlighting: light page → light theme, dark page → dark
// theme (toggled by the CSS below via --shiki-dark).
const codeThemes = { light: 'github-light-default', dark: 'github-dark-default' };

// Real code: the input-layer API from examples/input/input_mutex.rs (framework-level input mutex)
const layerCode = `// Request an input layer when entering edit mode
let edit_layer = hooks.use_input_layer(editing.get(), true);

// The handler only receives key events while this layer is active
hooks.use_event_handler(
    EventScope::Layer(edit_layer),
    EventPriority::High,
    move |event| {
        let Event::Key(key) = event else {
            return EventResult::Ignored;
        };
        match key.code {
            KeyCode::Enter => editing.set(false),
            KeyCode::Char(c) => draft.write().push(c),
            _ => {}
        }
        // The background list never sees these keys
        EventResult::Consumed
    },
);`;

const features = [
	{
		span: 'lg',
		token: 'element!',
		title: 'Declarative syntax',
		text: 'A JSX-style proc-macro — describe UI with data instead of hand-written draw calls. A syntax you already know, compiling component trees into terminal layout.',
		points: [
			'if / for / match are first-class inside child blocks',
			'{ expr } embeds any Rust expression returning an Element',
			'widget() / stateful() bridge native ratatui widgets',
		],
	},
	{
		span: 'wide',
		token: 'use_state · use_future',
		title: 'Hooks & state',
		text: 'use_state, use_future, use_effect and custom hooks are organized by call order. State handles are Copy, support operator overloading like count += 1, and release automatically when the component unmounts.',
	},
	{
		span: 'wide',
		token: 'use_input_layer',
		title: 'Input-layer mutex',
		text: 'Events are no longer broadcast to every component — they route to the active input layer. Request a layer when opening a modal or entering edit mode, and the background list yields the keyboard, killing focus contention at the root.',
	},
	{
		span: 'wide',
		token: 'Waker',
		title: 'Reactive rendering',
		text: 'State writes wake the render loop, so the framework only repaints on real change instead of imperatively redrawing. generational-box-based reactive handles let a terminal UI update on demand, like a frontend framework.',
	},
	{
		span: 'sm',
		token: 'Palette · ThemeOverride',
		title: 'Theming',
		text: 'A shared Palette is the single color source — every component derives its styles from it. Swap the palette to re-theme the whole tree, override one component type, or drive it from an Atom to re-theme at runtime.',
	},
	{
		span: 'sm',
		token: 'Select · Modal',
		title: 'Built-in components',
		text: 'Layout, input, overlays, selection and virtual lists work out of the box — business-neutral and composable.',
	},
	{
		span: 'sm',
		token: 'RouterProvider · Atom',
		title: 'Routing & global state',
		text: 'Router manages multiple pages and a history stack; Atom manages business state shared across pages.',
	},
];

// All built-in components: used by the "component showcase" scroll switcher. Snippets are taken from real usage in each component's docs.
const components = [
	{
		name: 'View · Border · Text',
		desc: 'The most basic layout and text primitives: flex containers, bordered grouping, paragraph rendering — slicing the component tree into predictable terminal regions.',
		gif: null,
		href: 'components/layout-primitives/',
		example: 'hello_world',
		code: `View(flex_direction: Direction::Vertical, gap: 1) {
    Text(text: "header")
    View(height: Constraint::Fill(1)) {
        Text(text: "body")
    }
    Text(text: "footer")
}`,
	},
	{
		name: 'ScrollView',
		desc: 'Scrollable container: content beyond the viewport renders into a larger buffer first, then displays by offset — supports j/k, paging and a scrollbar.',
		gif: 'scrollview',
		href: 'components/scroll-view/',
		example: 'scrollview',
		code: `ScrollView(
    flex_direction: Direction::Vertical,
    block: Block::bordered(),
) {
    for (i, row) in rows.iter().enumerate() {
        View(key: i, height: Constraint::Length(1)) {
            Text(text: row)
        }
    }
}`,
	},
	{
		name: 'WrappedText',
		desc: 'Long body text: hard-wraps at a given width, then writes the real line count back into layout height so the outer ScrollView computes the scroll range correctly.',
		gif: 'wrapped-text',
		href: 'components/wrapped-text/',
		example: 'wrapped_text',
		code: `ScrollView(scroll_view_state: scroll_state, block: Block::bordered()) {
    WrappedText(
        text: BODY,
        wrap_width: 72,
        style: Style::new().white(),
    )
}`,
	},
	{
		name: 'Input',
		desc: 'Display component for a single-line input box, rendering tui_input state; writing, submitting and exiting are all driven by the page handler.',
		gif: 'input',
		href: 'components/input/',
		example: 'input',
		code: `Border(height: Constraint::Length(3)) {
    Input(
        input: input.read().clone(),
        placeholder: "Type and press Enter".to_string(),
        cursor_style: Style::new().bg(Color::Yellow),
    )
}`,
	},
	{
		name: 'SearchInput',
		desc: 'Search box with an edit mode: press s to enter input and open an exclusive layer — wraps activation, submission, clearing, validation and input mutex.',
		gif: 'search-input',
		href: 'components/search-input/',
		example: 'search_input',
		code: `SearchInput(
    value: query.read().to_string(),
    placeholder: "Press s to search".to_string(),
    on_change: move |next: String| query.set(next),
    on_submit: move |value: String| {
        submitted.set(value);
        true
    },
)`,
	},
	{
		name: 'Modal',
		desc: 'Low-level overlay: draws the backdrop, positions content and provides the current input layer to its subtree — confirm and close logic are composed on top.',
		gif: 'modal',
		href: 'components/modal/',
		example: 'modal',
		code: `Modal(
    open: open.get(),
    width: Constraint::Length(68),
    height: Constraint::Length(12),
) {
    Border(top_title: Line::from("Details").centered()) {
        Text(text: Line::from("Modal content"))
    }
}`,
	},
	{
		name: 'ConfirmModal',
		desc: 'Confirmation dialog: builds an exclusive input layer internally, wrapping confirm/cancel, button focus switching and input mutex — controlled by open.',
		gif: 'confirm-modal',
		href: 'components/confirm-modal/',
		example: 'confirm_modal',
		code: `ConfirmModal(
    open: confirm_open.get(),
    title: Line::from("Delete release?"),
    content: format!("Remove {selected_label}?"),
    confirm_text: "Delete".to_string(),
    on_confirm: move |_: ()| confirm_open.set(false),
    on_cancel: move |_: ()| confirm_open.set(false),
)`,
	},
	{
		name: 'AlertModal',
		desc: 'Notice dialog: no confirm/cancel buttons, just shows a message and fires on_close when the close key is pressed, intercepting lower-layer input meanwhile.',
		gif: 'alert-modal',
		href: 'components/alert-modal/',
		example: 'alert_modal',
		code: `AlertModal(
    open: alert_open.get(),
    title: Line::from("Workspace is current"),
    message: format!("{selected_label} is synced."),
    on_close: move |_: ()| alert_open.set(false),
)`,
	},
	{
		name: 'ShortcutInfoModal',
		desc: 'Shortcut help dialog: shows shortcuts grouped by section; when content overflows it scrolls via an internal ScrollView while keeping the modal input mutex.',
		gif: 'shortcut-info-modal',
		href: 'components/shortcut-info-modal/',
		example: 'shortcut_info_modal',
		code: `ShortcutInfoModal(
    open: shortcuts_open.get(),
    title: Line::from("Shortcut reference"),
    sections: vec![ShortcutInfoSection::new(
        "Navigation",
        [("Down", "j"), ("Up", "k")],
    )],
    on_close: move |_: ()| shortcuts_open.set(false),
)`,
	},
	{
		name: 'Select',
		desc: 'Single-select list: holds a ListState internally, turning j/k, arrow keys, Home/End and Enter into list navigation and a select callback.',
		gif: 'select',
		href: 'components/select/',
		example: 'select',
		code: `Select<&'static str>(
    items: items,
    default_index: Some(1),
    highlight_symbol: "> ",
    empty_message: "No environments",
    on_select: move |item: &'static str| {
        selected.set(item);
    },
)`,
	},
	{
		name: 'MultiSelect',
		desc: 'Multi-select list: interaction has two levels — Space toggles the draft selection (fires on_change), Enter commits the selection (fires on_select).',
		gif: 'multi-select',
		href: 'components/multi-select/',
		example: 'multi_select',
		code: `MultiSelect<&'static str>(
    items: items,
    highlight_symbol: "> ",
    on_change: move |items: Vec<&'static str>| {
        selected_count.set(items.len());
    },
    on_select: move |items: Vec<&'static str>| {
        submitted.set(items.len());
    },
)`,
	},
	{
		name: 'TreeSelect',
		desc: 'Tree selection (tree feature): reuses tui-tree-widget for hierarchical navigation, collapse/expand, path-style selection and input mutex.',
		gif: 'tree-select',
		href: 'components/tree-select/',
		example: 'tree_select',
		code: `TreeSelect<&'static str>(
    active: true,
    items: demo_items(),
    default_selection: vec!["components", "select"],
    node_open_symbol: "- ",
    node_closed_symbol: "+ ",
    on_select: move |id: &'static str| {
        submitted.set(id);
    },
)`,
	},
	{
		name: 'VirtualList',
		desc: 'Long list (virtual-list feature): reuses tui-widget-list to render only the visible window — handles tens of thousands of rows with custom row rendering.',
		gif: 'virtual-list',
		href: 'components/virtual-list/',
		example: 'virtual_list',
		code: `VirtualList<Line<'static>>(
    item_count: 10_000,
    default_index: Some(42),
    render_item: |ctx: &ListBuildContext| {
        let style = if ctx.is_selected {
            Style::new().black().on_green()
        } else {
            Style::new()
        };
        (Line::styled(format!("row {:05}", ctx.index + 1), style), 1u16)
    },
)`,
	},
	{
		name: 'VirtualMultiSelect',
		desc: 'Composition for multi-selecting a long list: VirtualList manages the cursor and windowed rendering, while business code keeps the selection set in an external HashSet.',
		gif: 'virtual-multi-select',
		href: 'components/virtual-multi-select/',
		example: 'virtual_multi_select',
		code: `VirtualList<Line<'static>>(
    state: list_state,
    item_count: item_count,
    render_item: move |ctx: &ListBuildContext| {
        let mark = if selected.contains(&ctx.index) { "[x]" } else { "[ ]" };
        (Line::styled(format!("{mark} Row {:05}", ctx.index + 1), Style::default()), 1u16)
    },
)`,
	},
];

const pathItems = [
	{ title: 'Get it running', href: 'start/quick-start/', text: 'Build component intuition from hello world and counter.' },
	{ title: 'Understand the core model', href: 'core/component-model/', text: 'Grasp the boundaries of element, component, hooks, context and the render loop.' },
	{ title: 'Handle real input', href: 'tutorials/input-mutex/', text: 'Use input layers to resolve event ownership between modals, lists and edit modes.' },
	{ title: 'Extend the framework layer', href: 'advanced/custom-hook/', text: 'Distill providers, hooks and widgets to turn business constraints into reusable capability.' },
];

// Act one, "the collapse": the same counter that increments every second.
// Left: the imperative plain-ratatui version where you manage the terminal lifecycle, render loop, timer and event polling by hand.
const rawCode = `fn main() -> std::io::Result<()> {
    let mut terminal = ratatui::init(); // enter / exit the terminal by hand
    let mut count = 0_u64;              // state scattered across main
    let mut last = Instant::now();      // keep your own timer
    loop {                             // hand-written render loop
        terminal.draw(|f| ui(f, count))?;
        if last.elapsed() >= Duration::from_secs(1) {
            count += 1;                // advance state manually
            last = Instant::now();
        }
        if event::poll(Duration::from_millis(50))? {
            if let Event::Key(k) = event::read()? {
                if k.code == KeyCode::Char('q') {
                    break;             // handle exit yourself
                }
            }
        }
    }
    ratatui::restore();               // don't forget to restore the terminal
    Ok(())
}`;

// Right: the declarative ratatui-kit core. The runtime owns the terminal, loop and exit — you only describe state and UI.
const kitCoreCode = `#[component]
fn Counter(mut hooks: Hooks) -> impl Into<AnyElement<'static>> {
    let mut count = hooks.use_state(|| 0_u64);

    hooks.use_future(async move {
        loop {
            tokio::time::sleep(Duration::from_secs(1)).await;
            count += 1;
        }
    });

    element!(
        Border(border_style: Style::new().yellow()) {
            Text(text: Line::from(format!("Counter: {:02}", count.get())))
        }
    )
}`;

// The left copy switches between the two acts as you scroll (matching the two snippets in the right code window).
const rawNarr = {
	kicker: 'plain ratatui · manual',
	title: 'You do everything yourself',
	text: 'Enter and exit the terminal, hand-write the render loop, keep a timer with Instant, poll and dispatch every key — before the counter even starts, boilerplate already fills main.',
};
const kitNarr = {
	kicker: 'ratatui-kit · automatic',
	title: 'Just describe state and UI',
	text: 'use_state holds state, use_future runs async, element! declares the UI. Terminal lifecycle, render loop and exit are handled by the runtime — the same counter, half the code.',
};

// Act two, "running in three steps": install → write a component → run.
const cargoTomlCode = `[dependencies]
ratatui-kit = "${RK_VERSION}"
tokio = { version = "1", features = [
    "rt-multi-thread", "macros", "time",
] }`;

const counterFileCode = `use ratatui_kit::prelude::*;

#[tokio::main]
async fn main() {
    element!(Counter).fullscreen().await.unwrap();
}

#[component]
fn Counter(mut hooks: Hooks) -> impl Into<AnyElement<'static>> {
    let mut count = hooks.use_state(|| 0_u64);

    hooks.use_future(async move {
        loop {
            tokio::time::sleep(Duration::from_secs(1)).await;
            count += 1;
        }
    });

    element!(
        Border(border_style: Style::new().yellow()) {
            Text(text: Line::from(format!("Counter: {:02}", count.get())))
        }
    )
}`;

const qsSteps = [
	{
		n: '01',
		title: 'Add the dependency',
		text: 'Add ratatui-kit and Tokio to Cargo.toml. The framework enables no feature by default — turn on router, atom, input and so on as needed.',
	},
	{
		n: '02',
		title: 'Write your first component',
		text: 'use_state holds state, use_future runs async, element! declares UI. Component instances are retained across frames by the runtime, and writing state wakes rendering automatically.',
	},
	{
		n: '03',
		title: 'Run it',
		text: 'cargo run, and the terminal goes fullscreen. The counter increments every second — press q to quit, Ctrl+C to force-stop, and the terminal restores on exit.',
	},
];
---

<div class="rk-home" data-rk-home>
	<div class="rk-home__grain" aria-hidden="true"></div>

	<section class="rk-hero" aria-labelledby="rk-home-title">
		<div class="rk-hero__copy">
			<p class="rk-brand" data-rk-reveal>
				<span class="rk-brand__mark" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 700 724" aria-hidden="true">
<path d="M0,0 L434,0 L454,3 L474,9 L497,20 L511,30 L525,42 L535,53 L547,70 L558,93 L564,113 L567,133 L567,591 L564,611 L558,631 L547,654 L537,668 L525,682 L514,692 L497,704 L474,715 L454,721 L434,724 L0,724 L-20,721 L-40,715 L-63,704 L-77,694 L-91,682 L-101,671 L-113,654 L-124,631 L-130,611 L-133,591 L-133,133 L-130,113 L-124,93 L-113,70 L-103,56 L-91,42 L-80,32 L-63,20 L-40,9 L-20,3 Z " fill="#064A4F" transform="translate(133,0)"/>
<path d="M0,0 L96,0 L96,160 L93,180 L87,200 L76,223 L66,237 L54,251 L43,261 L26,273 L3,284 L-17,290 L-37,293 L-195,292 L-195,200 L-189,188 L-180,178 L-158,156 L-151,148 L-125,122 L-118,114 L-95,91 L-88,83 L-67,62 L-60,54 L-36,30 L-29,22 L-12,5 L-4,1 Z " fill="#FCA91C" transform="translate(604,431)"/>
<path d="M0,0 L8,0 L19,3 L28,9 L43,23 L56,35 L71,49 L86,63 L99,75 L114,89 L126,100 L143,116 L158,130 L171,142 L187,157 L200,169 L215,183 L228,195 L236,203 L241,213 L243,222 L242,233 L238,243 L231,252 L216,267 L208,274 L175,307 L167,314 L142,339 L134,346 L108,372 L100,379 L76,403 L68,410 L44,434 L36,441 L30,446 L22,450 L17,451 L5,451 L-6,447 L-15,440 L-21,430 L-23,424 L-23,408 L-18,396 L-9,386 L8,369 L15,361 L72,304 L79,296 L133,242 L137,234 L139,226 L138,215 L134,206 L127,198 L120,191 L112,184 L96,169 L81,155 L65,140 L52,128 L37,114 L22,100 L9,88 L-7,73 L-22,59 L-28,49 L-30,43 L-31,34 L-29,24 L-24,14 L-20,9 L-11,3 Z " fill="#FCF8EF" transform="translate(146,128)"/>
<path d="M0,0 L7,0 L7,60 L4,80 L-2,100 L-10,99 L-22,93 L-32,84 L-39,73 L-43,61 L-44,56 L-44,45 L-41,33 L-36,23 L-27,13 L-18,6 L-9,2 Z " fill="#064A4F" transform="translate(693,531)"/>
<path d="M0,0 L12,2 L20,7 L26,14 L30,24 L30,35 L27,44 L18,54 L9,58 L-1,59 L-11,56 L-20,50 L-26,40 L-27,37 L-27,22 L-22,12 L-17,7 L-9,2 Z " fill="#064A4F" transform="translate(557,565)"/>
<path d="M0,0 L8,1 L14,5 L18,12 L18,20 L13,28 L7,31 L-3,31 L-10,26 L-13,20 L-13,13 L-9,5 L-4,1 Z " fill="#064A4F" transform="translate(501,634)"/>
</svg>
				</span>
				<span class="rk-brand__word">RATATUI KIT</span>
			</p>
			<h1 id="rk-home-title" data-rk-reveal style="--i:1">Write terminal UIs as composable apps</h1>
			<p class="rk-hero__lead" data-rk-reveal style="--i:2">
				Components, hooks, input layers, routing and global state — the React-style model you already
				know, built on top of Ratatui and Tokio.
			</p>
			<div class="rk-actions" data-rk-reveal style="--i:3" aria-label="Homepage actions">
				<a class="rk-button rk-button--primary" data-magnetic href={`${baseUrl}start/quick-start/`}>
					<span>Get started</span>
					<span class="rk-button__icon" aria-hidden="true">→</span>
				</a>
				<a class="rk-button rk-button--ghost" href={repoUrl} target="_blank" rel="noreferrer">
					<span>View on GitHub</span>
					<span class="rk-button__icon" aria-hidden="true">↗</span>
				</a>
			</div>
		</div>

		<figure class="rk-window rk-window--term rk-hero__window" data-rk-reveal style="--i:2">
			<div class="rk-window__bar">
				<span class="rk-window__dots"><i></i><i></i><i></i></span>
				<span class="rk-window__name">cargo run --example todo_app</span>
			</div>
			<div class="rk-window__screen">
				<img
					src={recording('todo-app')}
					alt="Recording of a todo app built with ratatui-kit: add/remove tasks, filter and toggle status"
					loading="eager"
					decoding="async"
				/>
			</div>
		</figure>
	</section>

	<section class="rk-qs" aria-labelledby="rk-qs-title">
		{/* Act one: left copy + single right code window, scroll progress drives a typewriter (types raw in the first half, switches copy and retypes kit in the second) */}
		<div class="rk-qs-act rk-qs-act--versus" data-qs-act1 data-phase="raw">
			<div class="rk-qs-act__sticky">
				<header class="rk-qs-head">
					<p class="rk-qs-eyebrow" data-rk-reveal>Quick start</p>
					<h2 id="rk-qs-title" data-rk-reveal style="--i:1">The same counter, half the code</h2>
				</header>

				<div class="rk-qs-split">
					<div class="rk-qs-narrate">
						<div class="rk-qs-copy" data-qs-copy="raw">
							<span class="rk-qs-copy__kicker">{rawNarr.kicker}</span>
							<h3 class="rk-qs-copy__title">{rawNarr.title}</h3>
							<p>{rawNarr.text}</p>
						</div>
						<div class="rk-qs-copy" data-qs-copy="kit">
							<span class="rk-qs-copy__kicker">{kitNarr.kicker}</span>
							<h3 class="rk-qs-copy__title">{kitNarr.title}</h3>
							<p>{kitNarr.text}</p>
						</div>
						<div class="rk-qs-switch" aria-hidden="true">
							<span class="rk-qs-switch__tab" data-phase="raw">plain ratatui</span>
							<span class="rk-qs-switch__tab" data-phase="kit">ratatui-kit</span>
							<span class="rk-qs-switch__bar"><span class="rk-qs-switch__fill" data-qs-phasefill></span></span>
						</div>
					</div>

					<figure class="rk-window rk-window--code rk-qs-typer">
						<div class="rk-window__bar">
							<span class="rk-window__dots"><i></i><i></i><i></i></span>
							<span class="rk-window__name" data-qs-title>main.rs · plain ratatui</span>
						</div>
						<div class="rk-window__body rk-code rk-qs-typer__body">
							<div class="rk-qs-codelayer" data-qs-code="raw">
								<Code code={rawCode} lang="rust" themes={codeThemes} />
							</div>
							<div class="rk-qs-codelayer" data-qs-code="kit">
								<Code code={kitCoreCode} lang="rust" themes={codeThemes} />
							</div>
						</div>
					</figure>
				</div>
			</div>
		</div>

		{/* Act two: three steps to run — step progress advances with scroll, code window and terminal window switch in sync */}
		<div class="rk-qs-act rk-qs-act--steps" data-qs-act2 data-step="1">
			<div class="rk-qs-act2__grid">
				<div class="rk-qs-rail">
					<p class="rk-qs-rail__lead" data-rk-reveal>From an empty directory to a moving terminal — three steps.</p>
					<ol class="rk-qs-steps" data-qs-steps>
						<span class="rk-qs-steps__track" aria-hidden="true"><span class="rk-qs-steps__fill" data-qs-fill></span></span>
						{qsSteps.map((step, index) => (
							<li class="rk-qs-step" data-qs-step={index + 1}>
								<span class="rk-qs-step__dot" aria-hidden="true">{step.n}</span>
								<div class="rk-qs-step__body">
									<span class="rk-qs-step__title">{step.title}</span>
									<p>{step.text}</p>
								</div>
							</li>
						))}
					</ol>
				</div>

				<div class="rk-qs-stage">
					<div class="rk-qs-panel" data-qs-panel="1">
