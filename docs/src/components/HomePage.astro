	.rk-path,
	.rk-final {
		padding-block: clamp(4rem, 8vw, 7.5rem);
	}

	/* ===== Hero ===== */
	.rk-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
		align-items: center;
		gap: clamp(2rem, 5vw, 5rem);
		min-height: min(600px, calc(100dvh - 9rem));
		padding-block: clamp(2.25rem, 4.5vw, 4rem) clamp(2rem, 4vw, 3.4rem);
	}

	.rk-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		margin: 0 0 1.25rem;
		text-decoration: none;
	}

	.rk-brand__mark {
		display: grid;
		place-items: center;
		width: 1.65rem;
		height: 1.65rem;
		color: var(--rk-accent);
	}

	.rk-brand__mark svg {
		width: 100%;
		height: 100%;
	}

	.rk-brand__word {
		color: var(--rk-soft);
		font-size: 0.72rem;
		font-weight: 680;
		letter-spacing: 0.24em;
	}

	.rk-hero h1 {
		max-width: 16ch;
		font-size: clamp(2.2rem, 3.8vw, 3.4rem);
		letter-spacing: -0.022em;
	}

	.rk-hero__lead {
		max-width: 32rem;
		margin: 1.3rem 0 0;
		color: var(--rk-muted);
		font-size: clamp(1rem, 1.1vw, 1.08rem);
		line-height: 1.7;
	}

	.rk-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.rk-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.8rem;
		min-height: 3rem;
		padding: 0.45rem 0.5rem 0.45rem 1.3rem;
		border-radius: 999px;
		color: var(--rk-ink);
		text-decoration: none;
		font-weight: 640;
		font-size: 0.92rem;
		line-height: 1;
		white-space: nowrap;
		transition:
			transform 600ms var(--rk-ease),
			background 600ms var(--rk-ease),
			border-color 600ms var(--rk-ease),
			box-shadow 600ms var(--rk-ease);
	}

	.rk-button--primary {
		background: var(--rk-btn-bg);
		color: var(--rk-btn-ink);
		box-shadow: 0 16px 40px var(--rk-accent-glow);
	}

	.rk-button--primary:hover {
		box-shadow: 0 20px 52px var(--rk-accent-glow);
	}

	.rk-button--ghost {
		border: 1px solid var(--rk-line);
		background: var(--rk-card);
		color: var(--rk-ink);
	}

	.rk-button--ghost:hover {
		transform: translateY(-2px);
		border-color: var(--rk-line-strong);
		background: var(--rk-accent-glow);
	}

	.rk-button:active {
		transform: translateY(0) scale(0.98);
	}

	.rk-button__icon {
		display: grid;
		width: 2rem;
		height: 2rem;
		place-items: center;
		border-radius: 999px;
		font-size: 0.9rem;
		background: rgba(0, 0, 0, 0.14);
		transition:
			transform 600ms var(--rk-ease),
			background 600ms var(--rk-ease);
	}

	.rk-button--ghost .rk-button__icon {
		background: var(--rk-accent-glow);
		color: var(--rk-accent);
	}

	.rk-button:hover .rk-button__icon {
		transform: translate3d(3px, -1px, 0);
	}

	/* ===== Window shell: always a dark "terminal", floating on both light and dark pages ===== */
	.rk-window {
		margin: 0;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: var(--rk-radius);
		background: #0a2e32;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.06),
			0 34px 84px var(--rk-shadow);
		overflow: hidden;
	}

	:global([data-theme='light']) .rk-window {
		border-color: rgba(6, 74, 79, 0.12);
		box-shadow: 0 26px 60px rgba(6, 50, 54, 0.18);
	}

	.rk-window__bar {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.5rem 0.85rem;
		background: rgba(0, 0, 0, 0.18);
	}

	.rk-window__dots {
		display: flex;
		align-items: center;
		gap: 0.42rem;
	}

	.rk-window__dots i {
		display: block;
		margin: 0;
		width: 0.6rem;
		height: 0.6rem;
		border-radius: 999px;
		background: rgba(243, 240, 231, 0.18);
	}

	.rk-window__dots i:first-child {
		background: #fca91b;
	}

	.rk-window__name {
		color: rgba(243, 240, 231, 0.5);
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.74rem;
		letter-spacing: 0.01em;
	}

	.rk-window--code .rk-window__body {
		background:
			radial-gradient(circle at 80% -10%, rgba(252, 169, 27, 0.08), transparent 22rem),
			rgba(8, 7, 5, 0.5);
	}

	.rk-code :global(pre.astro-code) {
		margin: 0;
		padding: clamp(0.7rem, 1.2vw, 0.95rem) clamp(0.85rem, 1.3vw, 1.1rem);
		background: transparent !important;
		overflow-x: auto;
	}

	/* Code window: light pages use a light card (terminal window stays dark for the gif recordings) */
	:global([data-theme='light']) .rk-window {
		background: #ffffff;
		border-color: rgba(6, 74, 79, 0.1);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.7),
			0 18px 44px rgba(6, 50, 54, 0.1);
	}

	:global([data-theme='light']) .rk-window .rk-window__bar {
		background: #f6f1e7;
		border-bottom-color: rgba(6, 74, 79, 0.08);
	}

	:global([data-theme='light']) .rk-window .rk-window__name {
		color: rgba(7, 54, 58, 0.5);
	}

	:global([data-theme='light']) .rk-window .rk-window__dots i {
		background: rgba(6, 74, 79, 0.16);
	}

	:global([data-theme='light']) .rk-window .rk-window__dots i:first-child {
		background: #fca91b;
	}

	:global([data-theme='light']) .rk-window .rk-window__body {
		background: #ffffff;
	}

	/* shiki dual themes: light by default, dark pages switch to the --shiki-dark variable */
	:global([data-theme='dark']) .rk-code :global(pre.astro-code),
	:global([data-theme='dark']) .rk-code :global(pre.astro-code span) {
		color: var(--shiki-dark) !important;
		font-style: var(--shiki-dark-font-style) !important;
		font-weight: var(--shiki-dark-font-weight) !important;
		text-decoration: var(--shiki-dark-text-decoration) !important;
	}

	.rk-code :global(pre.astro-code code) {
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.8rem;
		line-height: 1.7;
	}

	.rk-window--term .rk-window__screen {
		padding: clamp(0.8rem, 1.4vw, 1.15rem);
		background:
			radial-gradient(circle at 50% 120%, rgba(252, 169, 27, 0.08), transparent 18rem),
			rgba(6, 5, 4, 0.6);
	}

	.rk-window--term img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 0.7rem;
		background: #06201f;
	}

	/* ===== Capability area: asymmetric bento (2×2 hero card + wide cards + small cards) ===== */
	.rk-feat {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-rows: minmax(168px, auto);
		gap: clamp(0.7rem, 1.3vw, 1.1rem);
	}

	.rk-feat-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
		padding: clamp(1.4rem, 2.2vw, 1.9rem);
		border: 1px solid var(--rk-line);
		border-radius: var(--rk-radius-sm);
		background:
			radial-gradient(circle at 0% 0%, var(--rk-accent-glow), transparent 16rem),
			var(--rk-card);
		box-shadow: 0 24px 56px var(--rk-shadow);
		transition:
			transform 700ms var(--rk-ease),
			border-color 700ms var(--rk-ease),
			box-shadow 700ms var(--rk-ease);
	}

	.rk-feat-card--lg {
		grid-column: span 2;
		grid-row: span 2;
		gap: 0.85rem;
		padding: clamp(1.7rem, 2.6vw, 2.4rem);
	}

	.rk-feat-card--wide {
		grid-column: span 2;
	}

	.rk-feat-card--sm {
		grid-column: span 1;
	}

	.rk-feat-card:hover {
		transform: translateY(-5px);
		border-color: var(--rk-line-strong);
		box-shadow: 0 36px 74px var(--rk-shadow);
	}

	.rk-feat-card__token {
		align-self: flex-start;
		padding: 0.32rem 0.62rem;
		border-radius: 0.55rem;
		background: var(--rk-accent-glow);
		color: var(--rk-accent);
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.76rem;
		letter-spacing: -0.01em;
	}

	.rk-feat-card__title {
		margin: 0;
		color: var(--rk-ink);
		font-size: 1.05rem;
		font-weight: 660;
		letter-spacing: -0.012em;
		line-height: 1.2;
	}

	.rk-feat-card--lg .rk-feat-card__title {
		font-size: clamp(1.25rem, 2vw, 1.6rem);
		letter-spacing: -0.02em;
	}

	.rk-feat-card p {
		margin: 0;
		color: var(--rk-muted);
		font-size: 0.92rem;
		line-height: 1.68;
	}

	.rk-feat-card--lg p {
		font-size: clamp(0.95rem, 1.1vw, 1.05rem);
		max-width: 34rem;
	}

	.rk-feat-card__points {
		margin: 0.4rem 0 0;
		margin-top: auto;
		padding: 1rem 0 0;
		list-style: none;
		display: grid;
		gap: 0.62rem;
		border-top: 1px solid var(--rk-line);
	}

	.rk-feat-card__points li {
		position: relative;
		padding-left: 1.3rem;
		color: var(--rk-muted);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.rk-feat-card__points li::before {
		content: "";
		position: absolute;
		left: 0.15rem;
		top: 0.52em;
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 999px;
		background: var(--rk-accent);
	}

	/* ===== Input-layer showcase ===== */
	.rk-layer {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: start;
	}

	/* Left copy is vertically centered and sticky within the viewport; the right demo (code window + recording) scrolls */
	.rk-layer__copy {
		position: sticky;
		top: 5.5rem;
		height: calc(100dvh - 9rem);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	@media (max-width: 980px) {
		.rk-layer__copy {
			position: static;
			height: auto;
			display: block;
		}
	}

	.rk-layer h2 {
		font-size: clamp(1.7rem, 2.8vw, 2.4rem);
	}

	.rk-layer__copy code {
		padding: 0.1rem 0.4rem;
		border-radius: 0.4rem;
		background: var(--rk-accent-glow);
		color: var(--rk-accent);
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.88em;
	}

	.rk-layer__demo {
		display: grid;
		gap: clamp(1rem, 2vw, 1.4rem);
	}

	.rk-textlink {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.5rem;
		color: var(--rk-accent);
		font-weight: 600;
		font-size: 0.94rem;
		text-decoration: none;
		transition: gap 500ms var(--rk-ease);
	}

	.rk-textlink span {
		transition: transform 500ms var(--rk-ease);
	}

	.rk-textlink:hover span {
		transform: translateX(4px);
	}

	/* ===== Quick start: two scroll-driven acts (the collapse → running in three steps) ===== */
	.rk-qs {
		padding-block: clamp(2rem, 4vw, 3.5rem);
	}

	.rk-qs-act--versus {
		min-height: 210vh;
	}


	.rk-qs-act__sticky,
	.rk-qs-act2__grid {
		position: sticky;
		top: 5.5rem;
	}

	.rk-qs-act__sticky {
		display: grid;
		gap: clamp(1.4rem, 3vw, 2.4rem);
		min-height: calc(100dvh - 7rem);
		align-content: center;
		padding-block: clamp(1rem, 3vh, 2rem);
	}

	.rk-qs-head {
		max-width: 46rem;
	}

	.rk-qs-eyebrow {
		margin: 0 0 0.8rem;
		color: var(--rk-accent);
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.74rem;
		font-weight: 680;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	.rk-qs-head h2 {
		font-size: clamp(1.75rem, 3vw, 2.55rem);
	}

	.rk-qs-head p {
		margin: 1rem 0 0;
		max-width: 42rem;
		color: var(--rk-muted);
		font-size: clamp(0.95rem, 1vw, 1.05rem);
		line-height: 1.72;
	}

	/* — Act one: left copy + right code window + scroll-driven typewriter — */
	.rk-qs .rk-code :global(pre.astro-code code) {
		font-size: 0.74rem;
		line-height: 1.62;
	}

	.rk-qs-split {
		display: grid;
		grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
		gap: clamp(1.6rem, 4vw, 3.5rem);
		align-items: center;
	}

	/* Left: copy (two stacked blocks that cross-fade by phase) */
	.rk-qs-narrate {
		position: relative;
		display: grid;
	}

	.rk-qs-copy {
		grid-area: 1 / 1;
		max-width: 30rem;
		opacity: 0;
		transform: translateY(10px);
		transition:
			opacity 0.5s var(--rk-ease),
			transform 0.5s var(--rk-ease);
		pointer-events: none;
	}

	[data-qs-act1][data-phase="raw"] .rk-qs-copy[data-qs-copy="raw"],
	[data-qs-act1][data-phase="kit"] .rk-qs-copy[data-qs-copy="kit"] {
		opacity: 1;
		transform: none;
		pointer-events: auto;
	}

	.rk-qs-copy__kicker {
		display: inline-block;
		margin-bottom: 0.75rem;
		padding: 0.25rem 0.66rem;
		border-radius: 999px;
		border: 1px solid var(--rk-line-strong);
		color: var(--rk-accent);
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.72rem;
		letter-spacing: 0.01em;
	}

	.rk-qs-copy__title {
		margin: 0;
		color: var(--rk-ink);
		font-size: clamp(1.4rem, 2.4vw, 2rem);
		font-weight: 680;
		letter-spacing: -0.02em;
		line-height: 1.16;
	}

	.rk-qs-copy p {
		margin: 0.85rem 0 0;
		color: var(--rk-muted);
		font-size: clamp(0.95rem, 1vw, 1.05rem);
		line-height: 1.72;
	}

	/* Left: phase-switch progress indicator */
	.rk-qs-switch {
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: center;
		gap: 0.7rem;
		margin-top: clamp(1.6rem, 3vw, 2.4rem);
	}

	.rk-qs-switch__tab {
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.76rem;
		font-weight: 640;
		color: var(--rk-soft);
		transition: color 0.4s var(--rk-ease);
	}

	[data-qs-act1][data-phase="raw"] .rk-qs-switch__tab[data-phase="raw"],
	[data-qs-act1][data-phase="kit"] .rk-qs-switch__tab[data-phase="kit"] {
		color: var(--rk-accent);
	}

	.rk-qs-switch__bar {
		position: relative;
		height: 3px;
		border-radius: 3px;
		background: var(--rk-line);
		overflow: hidden;
	}

	.rk-qs-switch__fill {
		position: absolute;
		inset: 0 auto 0 0;
		width: 0%;
		background: var(--rk-accent);
		transition: width 0.1s linear;
	}

	/* Right: typewriter code window (two stacked snippets, switched by phase) */
	.rk-qs-typer {
		margin: 0;
		will-change: opacity;
	}

	.rk-qs-typer__body {
		position: relative;
		height: clamp(400px, 52vh, 520px);
		overflow: hidden;
	}

	.rk-qs-codelayer {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.35s var(--rk-ease);
		pointer-events: none;
	}

	[data-qs-act1][data-phase="raw"] .rk-qs-codelayer[data-qs-code="raw"],
	[data-qs-act1][data-phase="kit"] .rk-qs-codelayer[data-qs-code="kit"] {
		opacity: 1;
		pointer-events: auto;
	}

	/* Typewriter: line-by-line reveal driven by JS adding .typed per scroll progress; the .is-typing gate guarantees the whole block shows without JS */
	[data-qs-act1].is-typing .rk-qs-codelayer :global(.astro-code .line) {
		opacity: 0;
	}

	[data-qs-act1].is-typing .rk-qs-codelayer :global(.astro-code .line.typed) {
		opacity: 1;
	}

	.rk-qs-codelayer :global(.astro-code .line.caret)::after {
		content: "▋";
		margin-left: 1px;
		color: var(--rk-accent);
		animation: rk-caret 1s steps(1) infinite;
	}

	@keyframes rk-caret {
		50% {
			opacity: 0;
		}
	}

	/* — Act two: left sticky three steps (cumulative highlight) + right Cargo.toml / main.rs / gif scrolling naturally — */
	.rk-qs-act2__grid {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
		gap: clamp(1.6rem, 4vw, 3.5rem);
		align-items: start;
	}

	.rk-qs-rail {
		position: sticky;
		top: 5.5rem;
		height: calc(100dvh - 9rem);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.rk-qs-rail__lead {
		margin: 0 0 1.8rem;
		color: var(--rk-ink);
		font-size: clamp(1.2rem, 1.8vw, 1.5rem);
		font-weight: 660;
		letter-spacing: -0.015em;
	}

	.rk-qs-steps {
		position: relative;
		list-style: none;
		margin: 0;
		padding: 0 0 0 2.6rem;
		display: grid;
		gap: clamp(1.4rem, 3vw, 2.2rem);
	}

	.rk-qs-steps__track {
		position: absolute;
		left: 0.95rem;
		top: 0.7rem;
		bottom: 0.7rem;
		width: 2px;
		border-radius: 2px;
		background: var(--rk-line);
		overflow: hidden;
	}

	.rk-qs-steps__fill {
		position: absolute;
		inset: 0 0 auto 0;
		height: 0%;
		background: var(--rk-accent);
		transition: height 0.3s var(--rk-ease);
	}

	.rk-qs-step {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1rem;
		align-items: start;
		opacity: 0.4;
		transition: opacity 0.45s var(--rk-ease);
	}

	.rk-qs-step.is-on {
		opacity: 1;
	}

	.rk-qs-step__dot {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 1.9rem;
		height: 1.9rem;
		margin-left: -2.6rem;
		border-radius: 999px;
		border: 1px solid var(--rk-line-strong);
		background: var(--rk-bg-base);
		color: var(--rk-soft);
		font-family: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, monospace;
		font-size: 0.72rem;
		font-weight: 660;
		transition:
			background 0.4s var(--rk-ease),
			border-color 0.4s var(--rk-ease),
			color 0.4s var(--rk-ease),
			box-shadow 0.4s var(--rk-ease);
	}

	.rk-qs-step.is-on .rk-qs-step__dot {
		border-color: var(--rk-accent);
		background: var(--rk-accent);
		color: var(--rk-btn-ink);
		box-shadow: 0 0 0 5px var(--rk-accent-glow);
	}

	.rk-qs-step__title {
		display: block;
		color: var(--rk-ink);
		font-size: 1.02rem;
		font-weight: 660;
		letter-spacing: -0.01em;
	}

	.rk-qs-step__body p {
		margin: 0.35rem 0 0;
		color: var(--rk-muted);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.rk-qs-stage {
		display: flex;
		flex-direction: column;
		gap: clamp(2rem, 5vh, 4rem);
	}

	.rk-qs-panel {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: clamp(420px, 56vh, 540px);
	}

	.rk-qs-panel .rk-window {
		margin: 0;
