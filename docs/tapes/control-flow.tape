Output docs/public/recordings/control-flow.gif
Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""
Type "cargo run --quiet --example control_flow"
Enter
Sleep 1s
Type "j"
Sleep 500ms
Type "j"
Sleep 500ms
Type "n"
Sleep 500ms
Type "k"
Sleep 500ms
Type "q"
Sleep 500ms
