Output docs/public/recordings/router.gif

Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""

Type "cargo run --quiet --example router"
Enter
Sleep 4s
Type "2"
Sleep 600ms
Type "j"
Sleep 500ms
Enter
Sleep 900ms
Type "b"
Sleep 700ms
Type "f"
Sleep 700ms
Type "3"
Sleep 700ms
Type "r"
Sleep 700ms
Type "q"
Sleep 500ms
