Output docs/public/recordings/custom-provider.gif

Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""

Type "cargo run --quiet --example custom_provider"
Enter
Sleep 4s
Type "t"
Sleep 900ms
Type "d"
Sleep 900ms
Type "t"
Sleep 900ms
Type "d"
Sleep 900ms
Type "t"
Sleep 900ms
Type "q"
Sleep 500ms
