Output docs/public/recordings/virtual-list.gif

Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""

Type "cargo run --quiet --example virtual_list"
Enter
Sleep 4s
Type "jj"
Sleep 800ms
Enter
Sleep 900ms
Type "jjjjjjjjjjjjjjjj"
Sleep 1200ms
Enter
Sleep 900ms
Type "e"
Sleep 1200ms
Type "q"
Sleep 500ms
