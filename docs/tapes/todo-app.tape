Output docs/public/recordings/todo-app.gif

Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""

Type "cargo run --quiet --example todo_app"
Enter
Sleep 4s
Type "j"
Sleep 600ms
Space
Sleep 700ms
Type "f"
Sleep 700ms
Type "a"
Sleep 700ms
Type "Draft release notes"
Sleep 800ms
Enter
Sleep 900ms
Type "d"
Sleep 900ms
Type "y"
Sleep 900ms
