Output docs/public/recordings/atom-state.gif

Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""

Type "cargo run --quiet --example atom_state"
Enter
Sleep 4s
Type "1"
Sleep 800ms
Type "write atom docs"
Sleep 800ms
Enter
Sleep 900ms
Type "2"
Sleep 800ms
Type "++"
Sleep 600ms
Type "-"
Sleep 700ms
Escape
Sleep 900ms
