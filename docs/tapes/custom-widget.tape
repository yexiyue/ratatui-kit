Output docs/public/recordings/custom-widget.gif

Set Width 1000
Set Height 600
Set FontSize 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env TERM "xterm-256color"
Env COLORTERM "truecolor"
Env NO_COLOR ""

Type "cargo run --quiet --example custom_widget"
Enter
Sleep 4s
Type "j"
Sleep 700ms
Type "j"
Sleep 700ms
Enter
Sleep 900ms
Type "k"
Sleep 700ms
Enter
Sleep 900ms
Type "q"
Sleep 500ms
